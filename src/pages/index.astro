---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BrowserFrameGraphic from '../components/BrowserFrameGraphic.astro';
import TrustStrip from '../components/TrustStrip.astro';
import ServiceListItem from '../components/ServiceListItem.astro';
import ReassuranceBanner from '../components/ReassuranceBanner.astro';
import FeaturedOfferCard from '../components/FeaturedOfferCard.astro';
import ProcessTeaser from '../components/ProcessTeaser.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../lib/site';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const featuredWork = (await getCollection('portfolio'))
  .filter((entry) => entry.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const latestPosts = (await getCollection('blog')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
---

<BaseLayout
  title={`${SITE.name} — Fast, SEO-First Websites for Small Businesses`}
  description={SITE.description}
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <h1 class="text-4xl font-medium tracking-tight text-ink sm:text-5xl">
          Websites that load fast and get found.
        </h1>
        <p class="mt-5 text-lg text-ink-secondary">
          Most small business websites are slow, generic, and hard to find in search. DEMWeb Studio builds ones that
          aren't — fast, SEO-first, and built around your business, from a first launch site to a full redesign.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href="/free-website-check" variant="secondary">Get a Free Website Check</Button>
          <Button href="/contact">Get a Free Call</Button>
        </div>
        <p class="mt-4 flex items-center gap-2 text-sm text-ink-secondary">
          <Icon name="IconRocket" class="size-4 shrink-0 text-teal" />
          Free, no-obligation call — most projects launched within 7 days.
        </p>
        <p class="mt-2 flex items-center gap-2 text-sm text-ink-secondary">
          <Icon name="IconMessage" class="size-4 shrink-0 text-teal" />
          See a first concept within 48 hours of our call.
        </p>
      </div>
      <div class="mx-auto hidden w-full max-w-md lg:mx-0 lg:block">
        <BrowserFrameGraphic />
      </div>
    </div>
  </section>

  <TrustStrip />

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-4">
      <h2 class="text-2xl font-medium text-ink sm:text-3xl">Services</h2>
      <a href="/services" class="text-sm font-medium text-teal hover:underline">View all services</a>
    </div>
    <p class="mt-2 text-sm text-ink-secondary">
      One-time project pricing, no subscriptions — and you work directly with me, start to finish.
    </p>
    <div class="mt-6 overflow-hidden rounded-2xl border border-border bg-card px-4 sm:px-6">
      {
        services.map((service) => (
          <ServiceListItem
            icon={service.data.icon}
            title={service.data.title}
            slug={service.data.slug}
            priceLabel={service.data.priceLabel}
            popular={service.data.popular}
          />
        ))
      }
    </div>
    <div class="mt-6">
      <FeaturedOfferCard />
    </div>
    <div class="mt-6">
      <ReassuranceBanner />
    </div>
  </section>

  <ProcessTeaser />

  {
    featuredWork.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between gap-4">
          <h2 class="text-2xl font-medium text-ink sm:text-3xl">Featured work</h2>
          <a href="/portfolio" class="text-sm font-medium text-teal hover:underline">
            See all work
          </a>
        </div>
        <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredWork.map(({ data }) => (
            <PortfolioCard
              title={data.title}
              slug={data.slug}
              summary={data.summary}
              siteType={data.siteType}
              focus={data.focus}
              performance={data.performance}
              image={data.image}
            />
          ))}
        </div>
        <div class="mt-8 rounded-2xl border border-border bg-card p-8 text-center sm:p-10">
          <h3 class="text-xl font-medium text-ink sm:text-2xl">Your business could be here next.</h3>
          <p class="mx-auto mt-3 max-w-xl text-ink-secondary">
            Every project starts with a free, no-obligation conversation about what you need — no pressure, no
            jargon, just a straight answer on scope and price.
          </p>
          <div class="mt-6">
            <Button href="/contact">Get a Free Call</Button>
          </div>
        </div>
      </section>
    )
  }

  {
    latestPosts.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between gap-4">
          <h2 class="text-2xl font-medium text-ink sm:text-3xl">Latest from the blog</h2>
          <a href="/blog" class="text-sm font-medium text-teal hover:underline">
            See all posts
          </a>
        </div>
        <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {latestPosts.map(({ data }) => (
            <BlogPostCard title={data.title} slug={data.slug} description={data.description} tags={data.tags} />
          ))}
        </div>
      </section>
    )
  }

  <ReviewsSection />
</BaseLayout>
