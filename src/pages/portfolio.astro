---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TagPill from '../components/TagPill.astro';
import PortfolioPlaceholderImage from '../components/PortfolioPlaceholderImage.astro';

const projects = (await getCollection('portfolio')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Website Portfolio & Case Studies"
  description="Case studies from DEMWeb Studio's self-built projects — the problems, the approach, and the results."
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-medium tracking-tight text-ink sm:text-5xl">
        Case Studies & Featured Work
      </h1>
      <p class="mt-5 text-lg text-ink-secondary">
        One of the projects below is this very site — real and currently live, not a concept. The rest are
        self-built concept sites, framed as case studies rather than a gallery, showing how we approach a project
        from problem to result. Real client work will replace the concepts as it lands.
      </p>
    </div>

    <div class="mt-12 space-y-10">
      {
        projects.map(({ data }) => (
          <article id={data.slug} class="overflow-hidden rounded-2xl border border-border bg-card">
            {
              data.image ? (
                <img
                  src={data.image}
                  alt={`Screenshot of the ${data.title} website homepage`}
                  class="aspect-[3/1] w-full object-cover"
                  loading="lazy"
                />
              ) : (
                <PortfolioPlaceholderImage aspect="banner" />
              )
            }
            <div class="p-6 sm:p-10">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <h2 class="text-2xl font-medium text-ink">{data.title}</h2>
                <div class="flex flex-wrap gap-2">
                  <TagPill icon="IconCode" label={data.siteType} />
                  <TagPill icon="IconSearch" label={data.focus} />
                  <TagPill icon="IconBolt" label={data.performance} />
                </div>
              </div>
              <p class="mt-3 text-ink-secondary">{data.summary}</p>

              <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3">
                <div>
                  <p class="text-sm font-medium text-teal">Problem</p>
                  <p class="mt-2 text-sm text-ink-secondary">{data.problem}</p>
                </div>
                <div>
                  <p class="text-sm font-medium text-teal">Approach</p>
                  <p class="mt-2 text-sm text-ink-secondary">{data.approach}</p>
                </div>
                <div>
                  <p class="text-sm font-medium text-teal">Result</p>
                  <p class="mt-2 text-sm text-ink-secondary">{data.result}</p>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>

  </section>
</BaseLayout>
