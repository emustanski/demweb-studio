---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist." noindex>
  <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6 lg:px-8">
    <span class="flex size-14 items-center justify-center rounded-2xl bg-teal-light text-2xl font-medium text-teal"
      >DW</span
    >
    <h1 class="mt-6 text-4xl font-medium tracking-tight text-ink sm:text-5xl">Page not found</h1>
    <p class="mt-4 text-lg text-ink-secondary">
      The page you're looking for doesn't exist, or has moved.
    </p>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a
        href="/"
        class="inline-flex items-center justify-center rounded-lg bg-teal px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-teal-hover"
      >
        Back to homepage
      </a>
      <a
        href="/contact"
        class="inline-flex items-center justify-center rounded-lg border border-border bg-card px-5 py-3 text-sm font-medium text-ink transition-colors hover:border-teal hover:text-teal"
      >
        Contact us
      </a>
    </div>
  </section>
</BaseLayout>
