---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogTagPill from '../../components/BlogTagPill.astro';
import { formatAbsoluteDate } from '../../lib/formatDate';

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Blog"
  description="Practical guidance on website cost, performance, and SEO for small businesses and freelancers."
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-medium tracking-tight text-ink sm:text-5xl">Blog</h1>
      <p class="mt-5 text-lg text-ink-secondary">
        Practical guidance on website cost, performance, and SEO — written for small businesses and freelancers, not
        for other developers.
      </p>
    </div>

    <div class="mx-auto mt-12 max-w-3xl divide-y divide-border">
      {
        posts.map((post) => (
          <article class="py-8 first:pt-0">
            <a href={`/blog/${post.data.slug}`} class="group">
              <h2 class="text-2xl font-medium text-ink transition-colors group-hover:text-teal">{post.data.title}</h2>
            </a>
            <time datetime={post.data.date.toISOString()} class="mt-2 block text-sm text-ink-muted">
              {formatAbsoluteDate(post.data.date.toISOString())}
            </time>
            <p class="mt-3 text-ink-secondary">{post.data.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <BlogTagPill label={tag} />
              ))}
            </div>
            <a
              href={`/blog/${post.data.slug}`}
              class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-teal hover:underline"
            >
              Read more
            </a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
