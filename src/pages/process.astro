---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Button from '../components/Button.astro';

const steps = [
  {
    icon: 'IconSearch',
    title: 'Discovery',
    description:
      "A short conversation about your business, your goals, and what your current site (if you have one) is missing. This is where scope and price get set — no surprises later. You'll see a first concept within 48 hours of our call.",
  },
  {
    icon: 'IconCode',
    title: 'Design',
    description:
      'A layout and content plan built around what your visitors need to see first, mapped out page by page before any code gets written. You review and approve the direction — headlines, structure, calls to action — before build work starts.',
  },
  {
    icon: 'IconRocket',
    title: 'Build',
    description:
      "The site gets built — fast, mobile-first, and structured for SEO from the start. You'll get progress check-ins with a live preview link as milestones are hit, so you can see the site taking shape rather than waiting for a single reveal at the end.",
  },
  {
    icon: 'IconBolt',
    title: 'Launch',
    description:
      'Final review, performance checks, and go-live. Domain, hosting, and analytics are set up so the site is fully yours from day one.',
  },
  {
    icon: 'IconMessage',
    title: 'Support',
    description:
      'Post-launch support covers fixes and small updates — broken links, content tweaks, styling issues you spot after launch. Anything bigger, like new pages or a redesign, gets scoped as its own project rather than folded in as an afterthought.',
  },
];
---

<BaseLayout
  title="My Website Design & Build Process"
  description="A five-step process from first conversation to post-launch support — built to remove the guesswork of hiring a freelance studio."
>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-medium tracking-tight text-ink sm:text-5xl">How We Work</h1>
      <p class="mt-5 text-lg text-ink-secondary">
        Hiring a freelance studio for the first time can feel uncertain. Here's exactly what happens, step by step.
      </p>
    </div>

    <ol class="mt-12 space-y-6">
      {
        steps.map((step, index) => (
          <li class="flex gap-5 rounded-2xl border border-border bg-card p-6 sm:p-8">
            <div class="flex flex-col items-center">
              <span class="flex size-11 shrink-0 items-center justify-center rounded-lg bg-teal-light text-teal">
                <Icon name={step.icon} class="size-5" />
              </span>
              {index < steps.length - 1 && <span class="mt-2 w-px flex-1 bg-border" />}
            </div>
            <div>
              <p class="text-sm font-medium text-ink-muted">Step {index + 1}</p>
              <h2 class="mt-1 text-xl font-medium text-ink">{step.title}</h2>
              <p class="mt-2 text-ink-secondary">{step.description}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="mt-12 flex flex-col items-start gap-4 rounded-2xl bg-teal-light p-8 sm:flex-row sm:items-center sm:justify-between sm:p-10">
      <p class="text-teal-deep">Ready to start with Discovery?</p>
      <Button href="/contact">Get a Free Call</Button>
    </div>
  </section>
</BaseLayout>
