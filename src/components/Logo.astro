---
import LogoMark from './LogoMark.astro';

interface Props {
  size?: 'default' | 'sm';
}

const { size = 'default' } = Astro.props;
const badgeSize = size === 'sm' ? 'size-8' : 'size-9';
const markSize = size === 'sm' ? 'size-[18px]' : 'size-5';
const textSize = size === 'sm' ? 'text-sm' : 'text-base';
---

<a href="/" class="flex items-center gap-2 text-ink" aria-label="DEMWeb Studio home">
  <span class:list={['flex items-center justify-center rounded-lg bg-teal text-white', badgeSize]}>
    <LogoMark class={markSize} />
  </span>
  <span class:list={['font-medium', textSize]}>DEMWeb Studio</span>
</a>
