---
import BlogTagPill from './BlogTagPill.astro';
import PortfolioPlaceholderImage from './PortfolioPlaceholderImage.astro';

interface Props {
  title: string;
  slug: string;
  description: string;
  tags: string[];
}

const { title, slug, description, tags } = Astro.props;

// No real photo makes sense for a blog post (nothing to screenshot), so
// every card uses the shared abstract placeholder — just with a
// topic-relevant icon derived from the post's own tags instead of a
// generic one, so cards still read as visually distinct from each other.
const ICONS_BY_TAG: Record<string, string> = {
  Pricing: 'IconCurrencyEuro',
  'Website Redesign': 'IconAlertTriangle',
  SEO: 'IconSearch',
};
const icon = tags.map((tag) => ICONS_BY_TAG[tag]).find(Boolean) ?? 'IconWorld';
---

<a
  href={`/blog/${slug}`}
  class="group flex h-full flex-col overflow-hidden rounded-2xl border border-border bg-card transition-shadow hover:shadow-lg hover:shadow-ink/5"
>
  <PortfolioPlaceholderImage aspect="video" icon={icon} />
  <div class="flex flex-1 flex-col p-6">
    <h3 class="line-clamp-1 text-lg font-medium text-ink transition-colors group-hover:text-teal">{title}</h3>
    <p class="mt-2 line-clamp-3 text-sm text-ink-secondary">{description}</p>
    <div class="mt-auto flex flex-wrap gap-2 pt-4">
      {tags.map((tag) => <BlogTagPill label={tag} />)}
    </div>
  </div>
</a>
