---
import Icon from './Icon.astro';
import Button from './Button.astro';

interface Props {
  icon: string;
  title: string;
  slug: string;
  priceLabel: string;
  summary: string;
  whatsIncluded: string[];
  popular?: boolean;
}

const { icon, title, slug, priceLabel, summary, whatsIncluded, popular = false } = Astro.props;
---

<div
  id={slug}
  class:list={[
    'flex flex-col rounded-2xl border bg-card p-6 sm:p-8',
    popular ? 'border-teal ring-1 ring-teal' : 'border-border',
  ]}
>
  <div class="flex items-start justify-between gap-3">
    <span class="flex size-11 items-center justify-center rounded-lg bg-teal-light text-teal">
      <Icon name={icon} class="size-6" />
    </span>
    {
      popular && (
        <span class="rounded-full bg-amber-badge-bg px-2.5 py-1 text-xs font-medium text-amber-badge-text">
          Popular
        </span>
      )
    }
  </div>

  <h3 class="mt-4 text-lg font-medium text-ink">{title}</h3>
  <p class="mt-2 text-sm text-ink-secondary">{summary}</p>

  <ul class="mt-5 flex-1 space-y-3">
    {
      whatsIncluded.map((item) => (
        <li class="flex items-start gap-2 text-sm text-ink-secondary">
          <Icon name="IconCheck" class="mt-0.5 size-4 shrink-0 text-teal" />
          <span>{item}</span>
        </li>
      ))
    }
  </ul>

  <div class="mt-6 flex flex-col items-start gap-3 border-t border-border pt-6 sm:flex-row sm:items-center sm:justify-between">
    <span class="text-base font-medium text-teal">{priceLabel}</span>
    <Button href={`/contact?interested=${encodeURIComponent(title)}`} size="sm">Get a Free Call</Button>
  </div>
</div>
