---
import Icon from './Icon.astro';
import Button from './Button.astro';
import Logo from './Logo.astro';
import { NAV_LINKS } from '../lib/site';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border bg-card/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <Logo />

    <nav class="hidden items-center gap-8 md:flex" aria-label="Primary">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-teal',
              currentPath === link.href ? 'text-teal' : 'text-ink-secondary',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <span class="hidden sm:inline-block">
        <Button href="/contact" size="sm">Contact</Button>
      </span>
      <button
        id="nav-menu-toggle"
        type="button"
        class="inline-flex size-9 items-center justify-center rounded-lg text-ink-secondary md:hidden"
        aria-expanded="false"
        aria-controls="nav-mobile-menu"
        aria-label="Toggle menu"
      >
        <Icon name="IconMenu" class="size-6" data-icon="menu" />
        <Icon name="IconX" class="hidden size-6" data-icon="close" />
      </button>
    </div>
  </div>

  <nav
    id="nav-mobile-menu"
    class="hidden flex-col gap-1 border-t border-border bg-card px-4 py-3 md:hidden"
    aria-label="Primary mobile"
  >
    {
      NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:bg-page',
            currentPath === link.href ? 'text-teal' : 'text-ink-secondary',
          ]}
        >
          {link.label}
        </a>
      ))
    }
    <Button href="/contact" size="sm" class="mt-1 text-center">Contact</Button>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-menu-toggle');
  const menu = document.getElementById('nav-mobile-menu');
  const menuIcon = toggle?.querySelector('[data-icon="menu"]');
  const closeIcon = toggle?.querySelector('[data-icon="close"]');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('flex');
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });
</script>
