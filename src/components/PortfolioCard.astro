---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import TagPill from './TagPill.astro';
import PortfolioPlaceholderImage from './PortfolioPlaceholderImage.astro';

interface Props {
  title: string;
  slug: string;
  summary: string;
  siteType: string;
  focus: string;
  performance: string;
  image?: string;
}

const { title, slug, summary, siteType, focus, performance, image } = Astro.props;

// Portfolio screenshots live in src/assets so Astro's build pipeline can
// generate resized, modern-format variants — a plain <img src="/public/...">
// would ship the same full-size PNG to every device regardless of the
// card's actual rendered size.
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/portfolio/*', { eager: true });
const imageModule = image ? images[`/src/assets/portfolio/${image.split('/').pop()}`] : undefined;
---

<a
  href={`/portfolio#${slug}`}
  class="group flex h-full flex-col overflow-hidden rounded-2xl border border-border bg-card transition-shadow hover:shadow-lg hover:shadow-ink/5"
>
  {
    imageModule ? (
      <Image
        src={imageModule.default}
        alt={`Screenshot of the ${title} website homepage`}
        class="aspect-video w-full object-cover"
        widths={[400, 800, 1200]}
        sizes="(min-width: 1024px) 368px, (min-width: 640px) 50vw, 100vw"
        loading="lazy"
      />
    ) : (
      <PortfolioPlaceholderImage aspect="video" />
    )
  }
  <div class="flex flex-1 flex-col p-6">
    <h3 class="line-clamp-1 text-lg font-medium text-ink transition-colors group-hover:text-teal">{title}</h3>
    <p class="mt-2 line-clamp-3 text-sm text-ink-secondary">{summary}</p>
    <div class="mt-auto flex flex-wrap gap-2 pt-4">
      <TagPill icon="IconCode" label={siteType} />
      <TagPill icon="IconSearch" label={focus} />
      <TagPill icon="IconBolt" label={performance} />
    </div>
  </div>
</a>
