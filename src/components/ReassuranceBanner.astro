---
import Button from './Button.astro';
---

<div
  class="flex flex-col items-start justify-between gap-6 rounded-2xl bg-teal-light px-6 py-8 sm:flex-row sm:items-center sm:px-10"
>
  <div>
    <p class="text-lg font-medium text-teal-deep">Not sure what you need?</p>
    <p class="mt-1 text-sm text-teal-deep/80">
      Get in touch and we'll find the best solution together — I reply within one business day.
    </p>
  </div>
  <Button href="/contact" class="shrink-0">Get in Touch</Button>
</div>
