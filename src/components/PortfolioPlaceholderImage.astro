---
// Abstract placeholder used wherever a content card has no real photo/
// screenshot (see CLAUDE.md Section 6 — geometric shapes, not stock
// photography). Originally portfolio-only, now shared with BlogPostCard.astro
// too since blog posts have nothing to screenshot — same visual language,
// just an optional topic-relevant icon swap. Two size presets: "video" for
// compact card teasers, "banner" for the full portfolio case-study page.
import Icon from './Icon.astro';

interface Props {
  aspect?: 'video' | 'banner';
  icon?: string;
}

const { aspect = 'video', icon = 'IconWorld' } = Astro.props;

const config = {
  video: {
    aspectClass: 'aspect-video',
    circle1: 'size-24 -left-6 -top-6',
    circle2: 'size-32 -bottom-8 -right-8',
    iconSize: 'size-10',
  },
  banner: {
    aspectClass: 'aspect-[3/1]',
    circle1: 'size-32 -left-8 -top-8',
    circle2: 'size-40 -bottom-10 -right-10',
    iconSize: 'size-12',
  },
}[aspect];
---

<div
  class={`relative flex ${config.aspectClass} w-full items-center justify-center overflow-hidden bg-gradient-to-br from-teal-light to-page`}
>
  <div class={`absolute ${config.circle1} rounded-full bg-teal/10`} />
  <div class={`absolute ${config.circle2} rounded-2xl bg-teal/10`} />
  <Icon name={icon} class={`relative ${config.iconSize} text-teal/70`} />
</div>
