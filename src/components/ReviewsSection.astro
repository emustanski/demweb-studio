---
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';

const testimonials = await getCollection('testimonials');
---

{
  testimonials.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-medium text-ink sm:text-3xl">What clients say</h2>
      <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {testimonials.map(({ data }) => (
          <figure class="rounded-2xl border border-border bg-card p-6">
            {data.rating && (
              <div class="flex gap-0.5 text-teal">
                {Array.from({ length: data.rating }).map(() => (
                  <Icon name="IconStar" class="size-4" />
                ))}
              </div>
            )}
            <blockquote class="mt-3 text-sm text-ink-secondary">"{data.quote}"</blockquote>
            <figcaption class="mt-4 text-sm font-medium text-ink">
              {data.name}
              <span class="block font-normal text-ink-muted">
                {data.role}, {data.company}
              </span>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>
  )
}
