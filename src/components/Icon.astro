---
// Minimal hand-rolled icon set, drawn in the Tabler Icons visual language
// (24x24, 2px stroke, currentColor) so the `icon` field on the services
// collection can store a portable Tabler icon name without adding the
// @tabler/icons package (not on the approved package list — see CLAUDE.md
// Section 1).
interface Props {
  name: string;
  class?: string;
  [attr: string]: unknown;
}

const { name, class: className = 'size-6', ...rest } = Astro.props;

const paths: Record<string, string> = {
  IconCode: '<path d="M7 8l-4 4l4 4" /><path d="M17 8l4 4l-4 4" /><path d="M14 4l-4 16" />',
  IconRefresh:
    '<path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4" /><path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4" />',
  IconGauge:
    '<circle cx="12" cy="12" r="9" /><path d="M12 12l3 -2" /><path d="M12 7v.01" /><path d="M16.243 8.757l-.005 .005" /><path d="M17.997 12.5l-.005 .005" /><path d="M7 12h.01" />',
  IconSearch: '<circle cx="10" cy="10" r="7" /><path d="M21 21l-6 -6" />',
  IconCheck: '<path d="M5 12l5 5l10 -10" />',
  IconArrowRight: '<path d="M5 12l14 0" /><path d="M13 18l6 -6" /><path d="M13 6l6 6" />',
  IconMenu: '<path d="M4 6l16 0" /><path d="M4 12l16 0" /><path d="M4 18l16 0" />',
  IconX: '<path d="M18 6l-12 12" /><path d="M6 6l12 12" />',
  IconMail:
    '<path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" /><path d="M3 7l9 6l9 -6" />',
  IconMapPin:
    '<path d="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0" /><path d="M17.657 16.657l-4.243 4.243a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0z" />',
  IconStar:
    '<path d="M12 17.75l-6.172 3.245l1.179 -6.873l-5 -4.867l6.9 -1l3.086 -6.253l3.086 6.253l6.9 1l-5 4.867l1.179 6.873z" />',
  IconBolt: '<path d="M13 3l0 7l6 0l-8 11l0 -7l-6 0l8 -11" />',
  IconWorld:
    '<circle cx="12" cy="12" r="9" /><path d="M3.6 9h16.8" /><path d="M3.6 15h16.8" /><path d="M11.5 3a17 17 0 0 0 0 18" /><path d="M12.5 3a17 17 0 0 1 0 18" />',
  IconMessage:
    '<path d="M8 9h8" /><path d="M8 13h6" /><path d="M18 4a3 3 0 0 1 3 3v8a3 3 0 0 1 -3 3h-5l-5 3v-3h-2a3 3 0 0 1 -3 -3v-8a3 3 0 0 1 3 -3h12z" />',
  IconRocket:
    '<path d="M4 13a8 8 0 0 1 7 7a6 6 0 0 0 3 -5a9 9 0 0 0 6 -8a3 3 0 0 0 -3 -3a9 9 0 0 0 -8 6a6 6 0 0 0 -5 3" /><path d="M7 14a6 6 0 0 0 -3 6a6 6 0 0 0 6 -3" /><path d="M15 9m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0" />',
  IconDeviceMobile: '<rect x="7" y="4" width="10" height="16" rx="1" /><path d="M11 17h2" />',
};

const svgPaths = paths[name] ?? paths.IconCode;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  {...rest}
  set:html={svgPaths}
/>
