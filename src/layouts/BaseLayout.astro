---
import '../styles/global.css';
// Astro's compiler bundles this + the two font-face imports below into one
// hashed CSS file per-build and auto-injects a single <link rel="stylesheet">
// for it (confirmed: same hashed filename across every page). It's the only
// render-blocking resource on the site — PageSpeed Insights flags ~200ms.
// A ?url import to hand-hoist that link earlier in <head> was tried and
// reverted: Astro/Vite doesn't dedupe it against the auto-bundled file, so it
// ships as a genuinely separate ~29KB stylesheet (missing the font-face rules
// too) instead of reusing the existing one — worse, not better. Deferring via
// rel=preload+swap was also rejected (see git history / prior planning docs)
// since ~100% of this site's visual styling is Tailwind utility classes in
// this one file — deferring it would cause a flash of unstyled content on
// every page, a worse trade-off than the ~200ms this would save. No clean
// fix exists within Astro's default CSS pipeline; left as-is.
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
// Preload the two actual latin woff2 files (the only subset this
// English-only site ever renders) so the browser fetches them in parallel
// with the CSS instead of waiting to parse it first and discover the
// @font-face rule. Unlike the CSS-hoist attempt above, this doesn't touch
// when styles apply — only when the font bytes start downloading — so no
// FOUC risk. Confirmed via build inspection: the hashed URL this resolves to
// is identical to the one the CSS bundle itself references, so the browser
// dedupes it to one request per file, not two.
import interLatin400 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import interLatin500 from '@fontsource/inter/files/inter-latin-500-normal.woff2?url';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../lib/site';
import { professionalServiceSchema } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
}

// ogImage defaults to one shared /og-image.svg for every page — deliberate,
// not an oversight: there's no image-generation tooling or per-page design
// assets in this project. Revisit once real branding/screenshots exist.
const { title, description, ogImage = '/og-image.svg', noindex = false } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
const pageTitle = title === SITE.name || title.startsWith(`${SITE.name} `) ? title : `${title} | ${SITE.name}`;
---

<!doctype html>
<html lang={Astro.currentLocale ?? 'en'}>
  <head>
    <meta charset="utf-8" />
    <link rel="preload" as="font" type="font/woff2" href={interLatin400} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interLatin500} crossorigin />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <!-- No twitter:site — omitted deliberately, no account handle exists yet. -->

    <meta name="google-site-verification" content="9gZGNlNUA3zMdpK9nBmFGgTdraoQJcRLhSpxuG6U7sE" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(professionalServiceSchema())} />

    <script
      is:inline
      type="module"
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "f4d7e03c1169499481d86a65d0d1c604"}'></script>
  </head>
  <body class="flex min-h-screen flex-col overflow-x-hidden">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
