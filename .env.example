# Copy to .env for local dev (Astro) and .dev.vars for local Pages Functions
# (wrangler pages dev). In production, set these as Cloudflare Pages secrets —
# see CLAUDE.md Section 1.

# Resend — contact form email delivery
RESEND_API_KEY=
# Currently emustanski@gmail.com; swap to hello@demwebstudio.com once
# Cloudflare Email Routing is live (one-line change, no restructuring).
RESEND_TO_EMAIL=emustanski@gmail.com
# Resend's shared testing domain until demwebstudio.com is verified in Resend.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cloudflare Turnstile
# Public key — exposed to the browser, safe to be public.
PUBLIC_TURNSTILE_SITE_KEY=
# Secret key — server-side only, used in functions/api/contact.ts.
TURNSTILE_SECRET_KEY=
